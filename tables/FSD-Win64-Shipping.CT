<?xml version="1.0" encoding="utf-8"?>
<CheatTable CheatEngineTableVersion="46">
  <CheatEntries>
    <CheatEntry>
      <ID>0</ID>
      <Description>"Weapon"</Description>
      <GroupHeader>1</GroupHeader>
      <CheatEntries>
        <CheatEntry>
          <ID>100</ID>
          <Description>"Infinite Ammo"</Description>
          <VariableType>Auto Assembler Script</VariableType>
          <AssemblerScript>[ENABLE]
aobscanmodule(ammo,FSD-Win64-Shipping.exe,89 8B 9C 06 00 00 48 8D)
aobscanmodule(ammo_born_ready,FSD-Win64-Shipping.exe,89 91 9C 06 00 00)
registersymbol(ammo)
registersymbol(ammo_born_ready)

ammo:
  db 90 90 90 90 90 90
ammo_born_ready:
  db 90 90 90 90 90 90

[DISABLE]
ammo:
  db 89 8B 9C 06 00 00
ammo_born_ready:
  db 89 91 9C 06 00 00

unregistersymbol(ammo)
unregistersymbol(ammo_born_ready)
</AssemblerScript>
          <Hotkeys>
            <Hotkey>
              <Action>Toggle Activation</Action>
              <Keys>
                <Key>112</Key>
              </Keys>
              <ID>0</ID>
              <ActivateSound>Activate</ActivateSound>
              <DeactivateSound>Deactivate</DeactivateSound>
            </Hotkey>
          </Hotkeys>
        </CheatEntry>
        <CheatEntry>
          <ID>200</ID>
          <Description>"No Reload"</Description>
          <VariableType>Auto Assembler Script</VariableType>
